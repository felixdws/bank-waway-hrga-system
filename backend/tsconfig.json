{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "types": ["node"]
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}